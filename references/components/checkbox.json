{
  "name": "Checkbox",
  "slug": "checkbox",
  "description": "Lets users select one or more options from a list, or toggle a single setting on/off.",
  "props": [
    { "name": "selected", "type": "boolean", "default": false },
    { "name": "indeterminate", "type": "boolean", "default": false },
    { "name": "state", "type": "enum", "options": ["default", "error", "disabled"], "default": "default" },
    { "name": "border", "type": "boolean", "default": true },
    { "name": "inverted", "type": "boolean", "default": false },
    { "name": "size", "type": "enum", "options": ["small", "medium"], "default": "medium" },
    { "name": "label", "type": "string", "default": "" },
    { "name": "value", "type": "string", "default": "" },
    { "name": "subtitle", "type": "string", "default": "" }
  ],
  "states": ["default", "error", "disabled"],
  "indeterminate": "Set indeterminate on a parent checkbox when only some of its children are selected. It shares the filled look with selected (same fills, borders, and hover colors); only the icon differs, showing a white horizontal dash instead of a check. Clicking it selects all children; clicking again deselects them.",
  "sizes": ["small", "medium"],
  "anatomy": [
    { "name": "Label", "description": "Text label above the checkbox" },
    { "name": "Info Icon", "description": "Optional info icon next to label" },
    { "name": "Input Container", "description": "Wrapper with 8px radius" },
    { "name": "Checkbox Icon", "description": "Square with rounded corners" },
    { "name": "Value", "description": "Text next to the checkbox icon" },
    { "name": "Error Icon", "description": "Shown in error state" }
  ],
  "dimensions": {
    "medium": {
      "containerHeight": 36,
      "paddingH": 8,
      "paddingCenter": 6,
      "checkboxIconSize": 24,
      "checkboxCornerRadius": 4.8
    },
    "small": {
      "containerHeight": 28,
      "paddingH": 6,
      "paddingCenter": 4,
      "checkboxIconSize": 16,
      "checkboxCornerRadius": 3.2
    }
  },
  "typography": {
    "label": {
      "medium": { "fontSize": 14, "lineHeight": 24, "fontWeight": 600 },
      "small": { "fontSize": 12, "lineHeight": 16, "fontWeight": 600 }
    },
    "value": {
      "medium": { "fontSize": 14, "lineHeight": 24, "fontWeight": 400 },
      "small": { "fontSize": 12, "lineHeight": 16, "fontWeight": 400 }
    },
    "valueWithSubtitle": {
      "medium": { "fontSize": 14, "lineHeight": 24, "fontWeight": 600 },
      "small": { "fontSize": 12, "lineHeight": 16, "fontWeight": 600 }
    },
    "subtitle": {
      "fontSize": 12,
      "lineHeight": 16,
      "fontWeight": 400
    }
  },
  "colors": {
