          "checkboxStrokeHover": "#a6b0be",
          "value": "#1d232c"
        },
        "selected": {
          "containerBg": "#e6f0fb",
          "border": "#006bd8",
          "borderHover": "#005fc0",
          "checkboxFill": "#006bd8",
          "checkboxFillHover": "#005fc0",
          "value": "#1d232c"
        }
      },
      "error": {
