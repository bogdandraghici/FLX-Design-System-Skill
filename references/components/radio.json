{
  "name": "Radio",
  "slug": "radio",
  "description": "Lets users pick exactly one option from a mutually exclusive set.",
  "props": [
    {
      "name": "selected",
      "type": "boolean",
      "default": false
    },
    {
      "name": "state",
      "type": "enum",
      "options": [
        "default",
        "error",
        "disabled"
      ],
      "default": "default"
    },
    {
      "name": "border",
      "type": "boolean",
      "default": true
    },
    {
      "name": "inverted",
      "type": "boolean",
      "default": false
    },
    {
      "name": "size",
      "type": "enum",
      "options": [
        "small",
        "medium"
      ],
      "default": "medium"
    },
    {
      "name": "label",
      "type": "string",
      "default": ""
    },
    {
      "name": "value",
      "type": "string",
      "default": ""
    },
    {
      "name": "subtitle",
      "type": "string",
      "default": ""
    }
  ],
  "states": [
    "default",
    "error",
    "disabled"
  ],
  "sizes": [
    "small",
    "medium"
  ],
  "anatomy": [
    {
      "name": "Label",
      "description": "Text label above the radio group"
    },
    {
      "name": "Input Container",
      "description": "Wrapper with 8px radius"
    },
    {
      "name": "Radio Icon",
      "description": "Circular selection indicator"
    },
    {
      "name": "Value",
      "description": "Text next to the radio icon"
    },
    {
      "name": "Error Icon",
      "description": "Shown in error state"
    }
  ],
  "dimensions": {
    "medium": {
      "containerHeight": 36,
      "paddingLeft": 8,
      "paddingRight": 12,
      "gap": 8,
      "radioIconSize": 24
    },
    "small": {
      "containerHeight": 28,
      "radioIconSize": 16
    }
  },
  "typography": {
    "label": {
      "medium": {
        "fontSize": 14,
        "lineHeight": 24,
        "fontWeight": 600
      },
      "small": {
        "fontSize": 12,
        "lineHeight": 16,
        "fontWeight": 600
      }
    },
    "value": {
      "medium": {
        "fontSize": 14,
        "lineHeight": 24,
        "fontWeight": 400
      },
      "small": {
        "fontSize": 12,
        "lineHeight": 16,
        "fontWeight": 400
      }
    },
    "valueWithSubtitle": {
      "medium": {
        "fontSize": 14,
        "lineHeight": 24,
        "fontWeight": 600
      },
      "small": {
        "fontSize": 12,
        "lineHeight": 16,
        "fontWeight": 600
      }
    },
    "subtitle": {
      "fontSize": 12,
      "lineHeight": 16,
      "fontWeight": 400
    }
  },
  "colors": {
    "light": {
      "default": {
        "unselected": {
          "containerBg": "#ffffff",
          "border": "#e3e8ed",
          "borderHover": "#cbd1db",
          "radioStroke": "#cbd1db",
          "radioStrokeHover": "#a6b0be",
          "value": "#1d232c"
        },
        "selected": {
          "containerBg": "#e6f0fb",
          "border": "#006bd8",
          "borderHover": "#005fc0",
          "radioFill": "#006bd8",
          "radioFillHover": "#005fc0",
          "value": "#1d232c"
        }
      },
      "error": {
        "unselected": {
          "containerBg": "#ffffff",
          "border": "#eb4e33",
          "borderHover": "#d11f00",
          "radioStroke": "#cbd1db",
          "radioStrokeHover": "#a6b0be",
          "value": "#1d232c"
        },
        "selected": {
          "containerBg": "#fde9e6",
          "border": "#e62200",
          "borderHover": "#d11f00",
          "radioFill": "#e62200",
          "radioFillHover": "#d11f00",
          "value": "#1d232c"
        }
      },
      "disabled": {
        "unselected": {
          "containerBg": "#e3e8ed",
          "border": "#e3e8ed",
          "radioStroke": "#64748b",
          "value": "#64748b"
        },
        "selected": {
          "containerBg": "#e3e8ed",
          "border": "#64748b",
          "radioFill": "#64748b",
          "value": "#64748b"
        }
      }
    },
    "dark": {
      "default": {
        "unselected": {
          "border": "#64748b",
          "borderHover": "#8390a2",
          "radioStroke": "#64748b",
          "radioStrokeHover": "#8390a2",
          "value": "#ffffff"
        },
        "selected": {
          "containerBg": "#002d5b",
          "border": "#3389e0",
          "borderHover": "#549ce5",
          "radioFill": "#3389e0",
          "radioFillHover": "#549ce5"
        }
      },
      "error": {
        "unselected": {
          "containerBg": "transparent",
          "border": "#eb4e33",
          "borderHover": "#ee6b54",
          "radioStroke": "#64748b",
          "radioStrokeHover": "#8390a2",
          "value": "#ffffff"
        },
        "selected": {
          "containerBg": "#610e00",
          "border": "#eb4e33",
          "borderHover": "#ee6b54",
          "radioFill": "#e62200",
          "radioFillHover": "#d11f00",
          "value": "#ffffff"
        }
      },
      "disabled": {
        "unselected": {
          "containerBg": "#475263",
          "border": "#5b6a7e",
          "radioStroke": "#64748b",
          "value": "#8390a2"
        },
        "selected": {
